{
  "name": "unibooking",
  "version": "0.1.4",
  "description": "Stateless, unified CRUD for booking & calendar providers (Google, Outlook, Square, Acuity, Apple/CalDAV, and more).",
  "type": "module",
  "license": "MIT",
  "author": "djlahre0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djlahre0/unibooking.git"
  },
  "homepage": "https://github.com/djlahre0/unibooking#readme",
  "bugs": {
    "url": "https://github.com/djlahre0/unibooking/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "calendar",
    "booking",
    "appointments",
    "scheduling",
    "google-calendar",
    "outlook",
    "square",
    "acuity",
    "caldav",
    "salon"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/*": {
      "import": {
        "types": "./dist/adapters/*.d.ts",
        "default": "./dist/adapters/*.js"
      },
      "require": {
        "types": "./dist/adapters/*.d.cts",
        "default": "./dist/adapters/*.cjs"
      }
    },
    "./webhooks/*": {
      "import": {
        "types": "./dist/webhooks/*.d.ts",
        "default": "./dist/webhooks/*.js"
      },
      "require": {
        "types": "./dist/webhooks/*.d.cts",
        "default": "./dist/webhooks/*.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "undici": "^6.21.0",
    "vitest": "^2.1.0"
  }
}
